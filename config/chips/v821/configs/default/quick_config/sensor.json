				},
				//set /dev/video0/1/4/5
				"vinc00": {
					"work_mode": "<0x1>",
					"status": "\"okay\""
				},
				"vinc01": {
					"vinc1_csi_sel": "<0>",
					"vinc1_mipi_sel": "<0>",
					"status": "\"okay\""
				},
				"vinc10": {
					"work_mode": "<0x1>",
