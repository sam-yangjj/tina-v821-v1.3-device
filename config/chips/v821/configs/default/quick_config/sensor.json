	/*****************************one_gc2083_and_one_os02g10_sensor************************************/
	"one_gc2083_and_one_os02g10_sensor": {
		"desc": "set dual camera of gc2083 and os02g10 for this board, mipi and dvp",
		"tag": "camera",
		"depends": [
			"default_sensor_config",
			"default_sensor_sys_config"
		],
		"board.dts": {
			"set_property": {
				//mem pool
				"size_pool": {
					"reg": "<0 0x82000000 0 0x01780000>"
				},
				"heap_size_pool@0": {
					"heap-size": "<0x01780000>",
					"thrs": "<100>",
					"sizes": "<0 24064>"
				},
				//pio
				"csi_mclk1_pins_a": {
					"pins": "\"PD2\"",
					"function": "\"ncsi\""
				},
				"csi_mclk1_pins_b": {
					"pins": "\"PD2\""
				},
				"gmac0": {
					"status": "\"disabled\""
				},
				//csi
				//csi0 enable smvs mode
				"csi0": {
					"pinctrl-0": "<&csi_sm_vs_pin_default>",
					"pinctrl-1": "<&csi_sm_vs_pin_sleep>"
				},
				"csi1": {
					"pinctrl-0": "<&ncsi_bt656_pins_a>",
					"pinctrl-1": "<&ncsi_bt656_pins_b>",
					"status": "\"okay\""
				},
				//tdm
				"tdm0": {
					"work_mode": "<0x1>"
				},
				//isp
				"isp00": {
					"work_mode": "<0x1>"
				},
				"isp01": {
					"status": "\"okay\"",
					"ldci_select": "<0x0>"
				},
				"isp10": {
					"status": "\"okay\""
				},
				//scaler
				"scaler00": {
					"work_mode": "<0x1>"
				},
				"scaler01": {
					"status": "\"okay\""
				},
				"scaler10": {
					"work_mode": "<0x1>",
					"status": "\"okay\""
				},
				"scaler11": {
					"status": "\"okay\""
				},
				"vind0": {
					"csi_top": "<240000000>"
				},
				//set sensor name and addr
				"sensor0": {
					"sensor0_mname": "\"os02g10_dvp\"",
					"sensor0_twi_addr": "<0x78>",
					"sensor0_mclk_id": "<1>",
