			"CONFIG_VIN_SENSOR_RESERVE_ADDR=0x81CEE000",
			"CONFIG_SENSOR_GC1084_MIPI=y",
			"# CONFIG_SUPPORT_ISP_TDM is not set",
			"# CONFIG_TDM_ONE_BUFFER is not set",
			"# CONFIG_SENSOR_GC2083_MIPI is not set",
			"# CONFIG_SENSOR_SC2336_MIPI is not set",
			"# CONFIG_SENSOR_SC3336_MIPI is not set",
			"# CONFIG_SENSOR_GC4663_MIPI is not set",
			"# CONFIG_SENSOR_F37P_MIPI is not set",
			"# CONFIG_SENSOR_GC1084_MIPI_USE_SAME_TWI is not set",
			"# CONFIG_SENSOR_NVP6158C is not set",
			"# CONFIG_SENSOR_GC05A2_MIPI is not set",
			"# CONFIG_FRAMEDONE_TWO_BUFFER is not set",
			"# CONFIG_ACTUATOR is not set",
			"# CONFIG_ACTUATOR_DW9714 is not set",
			"# CONFIG_SENSOR_F37P is not set",
			"# CONFIG_SENSOR_IMX258 is not set",
			"# CONFIG_SENSOR_OS02G10_DVP is not set",
			"# CONFIG_RT_MEDIA_DUAL_SENSOR is not set",
			"# CONFIG_SENSOR_GC2083_ONE_LANE_MIPI is not set",
			"# CONFIG_TDM_ONE_BUFFER_WITH_TWORX is not set",
			"# CONFIG_SENSOR_GC2083_SM_VSYNC_MODE is not set",
			"# CONFIG_SUPPORT_ISP_TDM is not set"
		],
		//cp vin driver and sensor to rootfs; see moudule.mk ;load ko see S00mpp
		"openwrt": [
			"CONFIG_gc1084=y",
			"# CONFIG_imx258 is not set",
			"# CONFIG_gc2053 is not set",
			"# CONFIG_gc2083 is not set",
			"# CONFIG_gc4663 is not set",
			"# CONFIG_f37p is not set",
			"# CONFIG_sc2336 is not set",
			"# CONFIG_sc3336 is not set",
			"# CONFIG_sc200ai is not set",
			"# CONFIG_bf2257cs is not set"
