		],
		"openwrt": [
			"glibc_defconfig.fragment"
		]
	},
	/*****************************set_cpu_vf_0************************************/
	"set_cpu_vf_0": {
		"desc": "Set CPU 960MHz (0.92v)",
		"tag": "cpucfg",
		"finish_note": [
			"Set CPU 960MHz successful.\n",
			"Please re-build pm firmware by\n",
			"mrtos pm && mrtos clean"
		],
		"board.dts": {
			"set_property": {
				"cpu0": {
					"operating-points-v2": "<&cpu_opp_table_vf0_1>"
				},
				"reg_vdd_cpu": {
					"regulator-min-microvolt": "<920000>",
					"regulator-max-microvolt": "<920000>"
				}
			}
		},
		"rtos": [
			"# CONFIG_SUNXI_VF_2_1 is not set"
		],
		"boot0": {
			"common.mk": {
				"CFG_SUNXI_VF_2_1": null
			}
		}
	},
	/*****************************set_cpu_vf_2************************************/
	"set_cpu_vf_2": {
		"desc": "Set cpu 1200MHz (1.00v)",
		"tag": "cpucfg",
		"finish_note": [
			"Set CPU 1200MHz successful.\n",
			"Please re-build pm firmware by\n",
			"mrtos pm && mrtos clean"
		],
		"board.dts": {
			"set_property": {
				"cpu0": {
					"operating-points-v2": "<&cpu_opp_table_vf2_1>"
				},
				"reg_vdd_cpu": {
					"regulator-min-microvolt": "<1000000>",
					"regulator-max-microvolt": "<1000000>"
				}
			}
		},
		"rtos": [
			"CONFIG_SUNXI_VF_2_1=y"
		],
		"boot0": {
			"common.mk": {
				"CFG_SUNXI_VF_2_1": true
			}
		}
	},
	/*****************************config_v821************************************/
	"config_v821": {
		"desc": "Set Driver config for V821",
		"tag": "cpucfg",
		"force_config": true,
		"depends": [
			"config_v821_integrated_wifi"
		],
		"boot0": {
			"common.mk": {
				"CFG_CHIP_V821": true,
				"CFG_V821B_CHIP": null
			}
		},
		"kernel": [
			"CONFIG_CHIP_V821=y",
			"# CONFIG_CHIP_V821B is not set"
		],
		"kernel_recovery": [
			"CONFIG_CHIP_V821=y",
			"# CONFIG_CHIP_V821B is not set"
		],
		"rtos": [
			"CONFIG_CHIP_V821=y",
			"# CONFIG_CHIP_V821B is not set"
		],
		"openwrt": [
			"# CONFIG_mpp_for_aw1931 is not set"
		]
	},
	/*****************************config_v821b************************************/
	"config_v821b": {
		"desc": "Set Driver config for V821B",
		"tag": "cpucfg",
		"force_config": true,
		"depends": [
			"config_v821b_integrated_wifi"
		],
		"boot0": {
			"common.mk": {
				"CFG_CHIP_V821": null,
				"CFG_V821B_CHIP": true
			}
		},
		"kernel": [
			"# CONFIG_CHIP_V821 is not set",
			"CONFIG_CHIP_V821B=y"
		],
		"kernel_recovery": [
			"# CONFIG_CHIP_V821 is not set",
			"CONFIG_CHIP_V821B=y"
		],
		"rtos": [
			"# CONFIG_CHIP_V821 is not set",
			"CONFIG_CHIP_V821B=y"
		],
		"openwrt": [
			"CONFIG_mpp_for_aw1931=y"
		]
	},
	/*****************************config_v821_integrated_wifi************************************/
	"config_v821_integrated_wifi": {
		"desc": "Set Wi-Fi Driver for V821",
		"tag": "cpucfg",
		"rtos": [
			"CONFIG_XRADIO_WLAN_PHY_COMP_USE_LIB=y",
			"# CONFIG_XRADIO_WLAN_PHY_COMP_USE_BIN is not set",
			"# CONFIG_XRADIO_WLAN_PHY_LIB_LINK_V821B is not set",
			"CONFIG_XRADIO_WLAN_PHY_LIB_LINK_V821=y"
		],
		"openwrt": [
			"CONFIG_PACKAGE_v821_wlan-firmware=y",
			"# CONFIG_PACKAGE_v821b_wlan-firmware is not set"
		]
	},
	/*****************************config_v821b_integrated_wifi************************************/
	"config_v821b_integrated_wifi": {
		"desc": "Set Wi-Fi Driver for V821B",
		"tag": "cpucfg",
		"rtos": [
			"CONFIG_XRADIO_WLAN_PHY_COMP_USE_LIB=y",
			"# CONFIG_XRADIO_WLAN_PHY_COMP_USE_BIN is not set",
			"# CONFIG_XRADIO_WLAN_PHY_LIB_LINK_V821 is not set",
			"CONFIG_XRADIO_WLAN_PHY_LIB_LINK_V821B=y",
			"# CONFIG_WLAN_STA_AUTO_PS_MODE is not set",
			"CONFIG_WLAN_STA_FORCE_PS_MODE=y"
		],
		"openwrt": [
			"CONFIG_PACKAGE_v821b_wlan-firmware=y",
			"# CONFIG_PACKAGE_v821_wlan-firmware is not set"
		]
	},
	/*****************************config_v821b_integrated_bluetooth_bluez************************************/
	"config_v821b_integrated_bluetooth": {
		"desc": "Set integrated bluetooth Driver bluez for V821B",
		"tag": "wlan",
		"kernel": [
			"CONFIG_BT_XR_SMD=m",
			"CONFIG_BT=y",
			"CONFIG_BT_LE_DISABLE_EXTERN=y",
			"# CONFIG_BT_DEBUGFS is not set"
		],
		"board.dts": {
			"add_node": [
				{
					"name": "&xrbt_smd"
				}
			],
			"set_property": {
				"xrbt_smd": {
					"status": "\"okay\""
				}
			}
		},
		"rtos": [
			"CONFIG_DRIVERS_BLUETOOTH_XRADIO=y",
			"CONFIG_BT_DRIVERS_LIB=y",
			"CONFIG_XRADIO_BT_CONTROLLER=y",
			"# CONFIG_SUN20IW2_BT_CONTROLLER is not set",
			"CONFIG_SUN300IW1_BT_CONTROLLER=y",
			"# CONFIG_DRIVER_SUN300IW1_BT_CONTROLLER_BLE_ONLY is not set",
			"CONFIG_DRIVER_SUN300IW1_BT_CONTROLLER_BLINK_BLE_ONLY=y",
			"# CONFIG_XRADIO_BT_CONTROLLER_CMD is not set",
			"CONFIG_BT_VHCI=y",
			"# CONFIG_BT_UART is not set",
			"CONFIG_COMPONENTS_AMP_BT=y",
			"# CONFIG_BT_DRIVERS_LOG is not set",
			"# CONFIG_BT_DIST_MODE_ALL is not set",
			"CONFIG_BT_DIST_MODE_CORRESPOND=y",
			"# CONFIG_BT_DIST_MODE_CORRESPOND_DEBUG is not set",
			"CONFIG_BT_DRIVERS_LIB_LOG_LEVEL=2"
		],
		"openwrt": [
			"CONFIG_PACKAGE_btmanager-v4.0=y",
			"CONFIG_BTMG_ENABLE_TTYS1=y",
			"# CONFIG_BTMG_ENABLE_TTYAS1 is not set",
			"# CONFIG_BTMG_ENABLE_TTYS2 is not set",
			"# CONFIG_BTMG_ENABLE_TTYAS2 is not set",
			"# CONFIG_ENABLE_CLASSIC_BLUETOOTH is not set",
			"CONFIG_ENABLE_LE_BLUETOOTH=y",
			"CONFIG_ENABLE_GATT_SERVER=y",
			"# CONFIG_ENABLE_GATT_CLIENT is not set",
			"CONFIG_BTMG_ENABLE_DEMO=y",
			"# CONFIG_ENABLE_DEMO_TERMINAL is not set",
			"# CONFIG_BTMG_ENABLE_MESH is not set",
			"CONFIG_PACKAGE_kmod-xradio-bt-smd=y",
			"# CONFIG_PACKAGE_libattr is not set",
			"# CONFIG_PACKAGE_glib2 is not set",
			"# CONFIG_PACKAGE_libdbus is not set",
			"# CONFIG_PACKAGE_libffi is not set",
			"# CONFIG_PACKAGE_libical is not set",
			"# CONFIG_PACKAGE_libncurses is not set",
			"# CONFIG_PACKAGE_libreadline is not set",
			"# CONFIG_PACKAGE_terminfo is not set",
			"# CONFIG_PACKAGE_bluez-daemon is not set",
			"# CONFIG_PACKAGE_bluez-utils is not set",
			"# CONFIG_PACKAGE_bluez-utils-btmon is not set",
			"# CONFIG_PACKAGE_bluez-utils-extra is not set",
			"# CONFIG_PACKAGE_dbus is not set",
			"CONFIG_PACKAGE_bluez-libs=y",
			"CONFIG_BLUEZ_UTILS_SIMPLE=y"
		]
	},
