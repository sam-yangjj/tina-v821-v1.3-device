	"post_cmd": {
		"nor": [
			"grep \"#define AGLINK_VERSION\" ${LICHEE_TOP_DIR}/bsp/include/uapi/aglink/ag_proto.h | sed 's/.*\"\\([^\"]*\\)\".*/\\1/' > ${rootfs}/etc/ag_user_version.conf",
			"${LICHEE_TOP_DIR}/openwrt/openwrt/staging_dir/host/bin/mksquashfs4 ${plat}/configs/user-resource ${configs}/user.squashfs -nopad -noappend -root-owned -comp lzo -b 32k -processors 16",
			"dd if=${configs}/user.squashfs of=${configs}/user.fex bs=128k conv=sync",
			"cp ${configs}/user.fex ${LICHEE_PACK_OUT_DIR} -r"
		],
		"default": [
			"grep \"#define AGLINK_VERSION\" ${LICHEE_TOP_DIR}/bsp/include/uapi/aglink/ag_proto.h | sed 's/.*\"\\([^\"]*\\)\".*/\\1/' > ${dir}/etc/ag_user_version.conf",
