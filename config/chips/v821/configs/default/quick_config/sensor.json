	/*****************************one_nvp6158c_sensor************************************/
	"one_nvp6158c_sensor": {
		"desc": "set nvp6158c 2H for this board",
		"tag": "camera",
		"depends": [
			"default_sensor_config",
			"default_sensor_sys_config"
		],
		"board.dts": {
			"set_property": {
				//spi1
				"spi1": {
					"status": "\"disabled\""
				},
				//gmac0
				"gmac0": {
					"status": "\"disabled\""
				},
				//pio
				"csi_mclk1_pins_a": {
					"pins": "\"PD2\"",
					"function": "\"ncsi\""
				},
				"csi_mclk1_pins_b": {
					"pins": "\"PD2\""
				},
				//csi1
				"csi1": {
					"status": "\"okay\""
				},
				//
				//isp10
				"isp10": {
					"status": "\"okay\""
				},
				//set sensor name and addr
				"sensor0": {
					"sensor0_mname": "\"nvp6158\"",
					"sensor0_twi_addr": "<0x64>",
					"sensor0_mclk_id": "<1>",
					"sensor0_isp_used": "<0>",
					"sensor0_fmt": "<0>",
					"sensor0_reset": "<&pio PD 17 GPIO_ACTIVE_LOW>",
					"status": "\"okay\""
				},
				//set /dev/video0/4
				"vinc00": {
					"vinc0_csi_sel": "<1>",
					"vinc0_mipi_sel": "<0xff>",
					"vinc0_isp_sel": "<4>",
					"vinc0_tdm_rx_sel": "<0xff>",
					"status": "\"okay\""
				},
				"vinc10": {
					"vinc4_csi_sel": "<1>",
					"vinc4_mipi_sel": "<0xff>",
					"vinc4_isp_sel": "<4>",
					"vinc4_isp_tx_ch": "<1>",
					"status": "\"okay\""
				}
			}
		},
		//enable sensor complile
		"kernel": [
			"# CONFIG_SENSOR_GC1084_MIPI is not set",
			"CONFIG_SENSOR_NVP6158C=m",
			"CONFIG_BT656=y"
		],
		//cp vin driver and sensor to rootfs; see moudule.mk ;load ko see S00mpp
		"openwrt": [
			"CONFIG_PACKAGE_kmod-sensor-nvp6158c=y",
			"# CONFIG_PACKAGE_kmod-sensor-gc1084 is not set",
			"# CONFIG_gc1084 is not set"
		]
	}, //end of one_nvp6158c_sensor
	/*****************************one_sc3336_sensor************************************/
