			"CONFIG_PACKAGE_kmod-sunxi-vin=y",
			"CONFIG_PACKAGE_kmod-sensor-sc3336=y",
			"CONFIG_sc3336=y",
			"# CONFIG_PACKAGE_kmod-sensor-gc1084 is not set",
			"# CONFIG_gc1084 is not set"
