	/*****************************v821_smac************************************/
	"v821_smac": {
		"desc": "set v821 smac for this board",
		"tag": "wlan",
		"board.dts": {
			"set_property": {
				"hifbypass": {
					"status": "\"okay\""
				}
			}
		},
		"kernel": [
			"# CONFIG_V821_FMAC_WLAN is not set",
			"# CONFIG_V821_FMAC_RPMSG is not set",
			"CONFIG_V821_SMAC_WLAN=m",
			"CONFIG_AW_RFKILL=y",
			"CONFIG_CFG80211=y",
			"CONFIG_CRYPTO_ARC4=y",
			"CONFIG_CRYPTO_AES=y",
			"CONFIG_CRYPTO_CCM=y",
			"CONFIG_CRYPTO_GCM=y",
			"CONFIG_CRYPTO_CMAC=y",
			"CONFIG_AW_SBI=y",
			"CONFIG_AW_MACADDR_MGT=y",
			"CONFIG_PM=y"
		],
		"openwrt": [
			"# CONFIG_WMG_PLATFORM_XRLINK is not set",
			"CONFIG_WMG_PLATFORM_LINUX=y",
			"CONFIG_PACKAGE_kmod-cfg80211=y",
			"# CONFIG_PACKAGE_kmod-net-v821_fmac is not set",
			"CONFIG_PACKAGE_kmod-net-v821_smac=y",
			"CONFIG_PACKAGE_hostapd-common=y",
			"CONFIG_WPA_MSG_MIN_PRIORITY=3",
			"CONFIG_PACKAGE_wpad-basic-openssl=y",
			"CONFIG_BUSYBOX_CONFIG_UDHCPC=y",
			"CONFIG_PACKAGE_dnsmasq=y"
		],
		"rtos": [
			"# CONFIG_INIT_NET_STACK is not set",
			"CONFIG_DRIVERS_V821_USE_SIP_WIFI=y"
		]
	}, //end of v821_smac
