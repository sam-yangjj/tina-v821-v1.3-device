		]
	},
	/*****************************one_sc2336_sensor************************************/
	"one_sc2336_sensor": {
		"desc": "set one camera of sc2336 online for this board",
		"tag": "camera",
		"depends": [
			"default_sensor_config",
			"default_sensor_sys_config"
		],
		"board.dts": {
			"set_property": {
				//s0vencfg0
				"s0vencfg0": {
					"status": "\"okay\"",
					"res_w": "<1920>",
					"res_h": "<1080>",
					"bit_rate": "<1024>",
					"jpg_w": "<1920>",
					"jpg_h": "<1080>"
				},
				//set sensor name and addr
				"sensor0": {
					"sensor0_mname": "\"sc2336_mipi\"",
					"sensor0_twi_addr": "<0x60>"
				}
			}
		},
		// enable sensor complile
		"kernel": [
			"CONFIG_SENSOR_SC2336_MIPI=y",
			"# CONFIG_SENSOR_GC1084_MIPI is not set"
		],
		// rtos configs
		"rtos_sysconfig": {
			"vind/sensor0": {
				"sensor0_mname": "\"sc2336_mipi\"",
				"sensor0_twi_addr": "0x60"
			},
			"vind/vinc0": {
				"vinc0_mipi_num": "2"
			},
			"vind/vinc4": {
				"vinc4_mipi_num": "2"
			}
		},
		// rtos configs
		"rtos": [
			"# CONFIG_SENSOR_GC1084_MIPI is not set",
			"CONFIG_SENSOR_SC2336_MIPI=y"
		]
	}, //end of one_sc2336_sensor
