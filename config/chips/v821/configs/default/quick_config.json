/*
*--Instructions--
* name_of_configuare : {
*	"sysconfig" : {}, ==> sys_config.fex
*	"board.dts" : {}, ==> board.dts
*	"bootpkg" : {}, ==>boot_package.cfg
*	"env" : {}, ==> env.cfg
*   "uboot-board.dts" : {}, ==>uboot-board.dts
*   "partition" ==> sys_partition.fex
*   "kernel" : {}, ==>linux-5.4-ansc/bsp_defconfig
*	"openwrt" : {}, ==>openwrt/target/xxx/defconfig
*},
*/
{
	/*****************************musl_toolchain************************************/
	"musl_toolchain": {
		"desc": "Change this board cross toolchain to musl",
		"check_distclean": true,
		"tag": "toolcahin",
		"prepare_note": [
			"IMPORTANT!! Set musl toolchain Note. IMPORTANT!!\n",
			"If the SDK has been compiled before, please clean up the previously compiled file and library with: \n",
			"`croot` to SDK root then `make distclean`\n",
			"After clean up, you can use quick_config to change toolcahin",
			"如果之前已经编译过 SDK，请先清理之前编译的文件和库：\\n",
			"先 `croot` 回到 SDK 根目录，然后执行 `make distclean`\\n",
			"清理完成后，即可使用 quick_config 切换工具链"
		],
		"finish_note": [
			"Set musl toolchain successful.\n"
		],
		"openwrt": [
			"musl_defconfig.fragment"
		]
	},
	/*****************************glibc_toolchain************************************/
	"glibc_toolchain": {
		"desc": "Change this board cross toolchain to glibc",
		"check_distclean": true,
		"tag": "toolcahin",
		"prepare_note": [
			"IMPORTANT!! Set glibc toolchain Note. IMPORTANT!!\n",
			"If the SDK has been compiled before, please clean up the previously compiled file and library with: \n",
			"`croot` to SDK root then `make distclean`\n",
			"After clean up, you can use quick_config to change toolcahin",
			"如果之前已经编译过 SDK，请先清理之前编译的文件和库：\\n",
			"先 `croot` 回到 SDK 根目录，然后执行 `make distclean`\\n",
			"清理完成后，即可使用 quick_config 切换工具链"
		],
		"finish_note": [
