	/*****************************dual_gc2083_sensor************************************/
	"dual_gc2083_sensor": {
		"desc": "set two camera of gc2083 online for this board",
		"tag": "camera",
		"depends": [
			"default_sensor_sys_config",
			"default_dual_sensor_config"
		],
		"board.dts": {
			"set_property": {
				"size_pool": {
					"reg": "<0 0x82000000 0 0x01E00000>"
				},
				"heap_size_pool@0": {
					"heap-size": "<0x01E00000>",
					"thrs": "<100>",
					"sizes": "<0 30720>"
				},
				"s0vencfg0": {
					"status": "\"okay\"",
					"res_w": "<1920>",
					"res_h": "<1080>",
					"bit_rate": "<1024>",
					"jpg_w": "<1920>",
					"jpg_h": "<1080>"
				},
				"s1vencfg0": {
					"status": "\"okay\"",
					"res_w": "<1920>",
					"res_h": "<1080>",
					"bit_rate": "<1024>"
				},
				"s2vencfg0": {
					"status": "\"disabled\""
				},
				"sensor0": {
					"sensor0_mname": "\"gc2083_mipi\"",
					"sensor0_twi_addr": "<0x6e>",
					"status": "\"okay\""
				},
				"sensor1": {
					"sensor1_mname": "\"gc2083_mipi_2\"",
					"sensor1_twi_addr": "<0x7e>",
					"status": "\"okay\""
				}
			}
		},
		"kernel": [
			"# CONFIG_SENSOR_GC1084_MIPI is not set",
			"CONFIG_SENSOR_GC2083_MIPI=y",
			"CONFIG_SENSOR_GC2083_ONE_LANE_MIPI=y",
			"CONFIG_TDM_ONE_BUFFER=y",
			"CONFIG_FRAMEDONE_TWO_BUFFER=y"
		],
		// rtos sysconfig
		"rtos_sysconfig": {
			"vind/sensor0": {
				"sensor0_mname": "\"gc2083_mipi\""
			},
			"vind/sensor1": {
				"sensor1_mname": "\"gc2083_mipi_2\"",
				"sensor1_twi_addr": "0x7e"
			},
			"vind/vinc0": {
				"vinc0_mipi_num": "1"
			},
			"vind/vinc1": {
				"vinc1_mipi_num": "1"
			}
		},
		// rtos configs
		"rtos": [
			"CONFIG_ISP_READ_THRESHOLD=y",
			"# CONFIG_SENSOR_GC1084_MIPI is not set",
			"# CONFIG_SENSOR_GC1084_MIPI_USE_SAME_TWI is not set",
			"CONFIG_SENSOR_GC2083_MIPI=y",
			"CONFIG_SENSOR_GC2083_MIPI_USE_1LANE=y",
			"CONFIG_TDM_RX_BUF_NUM=1"
		]
	}, //end of dual_gc2083_sensor
